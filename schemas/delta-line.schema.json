{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mesharkade.dev/schemas/delta-line.schema.json",
  "title": "Delta Line",
  "description": "Schema for a delta JSONL line for incremental catalog updates",
  "type": "object",
  "required": ["op"],
  "properties": {
    "op": {
      "type": "string",
      "enum": ["upsert", "remove"],
      "description": "Operation type: upsert adds/updates a game entry, remove deletes one"
    },
    "key": {
      "type": "string",
      "description": "Key used to identify the entry for removal operations (required for remove, unused for upsert)"
    },
    "source": {
      "type": "string",
      "description": "The source DAT provider (e.g., 'no-intro', 'redump', 'tosec', 'mame')"
    },
    "system": {
      "type": "string",
      "description": "The game system/platform identifier"
    },
    "datVersion": {
      "type": "string",
      "description": "Version of the source DAT file"
    },
    "id": {
      "type": "string",
      "description": "Unique identifier for this game entry"
    },
    "name": {
      "type": "string",
      "description": "Name of the game"
    },
    "description": {
      "type": "string",
      "description": "Optional description of the game"
    },
    "category": {
      "type": "string",
      "description": "Optional category (e.g., 'BIOS', 'Games', 'Applications')"
    },
    "cloneofid": {
      "type": "string",
      "description": "Optional ID of the parent clone this is a clone of"
    },
    "roms": {
      "type": "array",
      "description": "Array of ROM entries for this game",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "size", "crc"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the ROM file"
          },
          "size": {
            "type": "integer",
            "description": "Size in bytes"
          },
          "crc": {
            "type": "string",
            "pattern": "^[0-9a-fA-F]{8}$",
            "description": "CRC32 hash in hex"
          },
          "md5": {
            "type": "string",
            "pattern": "^[0-9a-fA-F]{32}$",
            "description": "MD5 hash in hex"
          },
          "sha1": {
            "type": "string",
            "pattern": "^[0-9a-fA-F]{40}$",
            "description": "SHA1 hash in hex"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-fA-F]{64}$",
            "description": "SHA256 hash in hex"
          },
          "status": {
            "type": "string",
            "description": "Optional status (e.g., 'verified', 'bad dump')"
          },
          "header": {
            "type": "string",
            "description": "Optional header information"
          }
        }
      }
    },
    "disks": {
      "type": "array",
      "description": "Array of disk/CHD entries (MAME disk images)",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the disk/CHD image"
          },
          "sha1": {
            "type": "string",
            "pattern": "^[0-9a-fA-F]{40}$",
            "description": "SHA1 hash in hex"
          },
          "md5": {
            "type": "string",
            "pattern": "^[0-9a-fA-F]{32}$",
            "description": "MD5 hash in hex"
          },
          "status": {
            "type": "string",
            "description": "Optional status (e.g., 'good', 'baddump')"
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "op": { "const": "remove" } } },
      "then": {
        "required": ["key"],
        "properties": {
          "source": { "not": {} },
          "system": { "not": {} },
          "datVersion": { "not": {} },
          "id": { "not": {} },
          "name": { "not": {} },
          "description": { "not": {} },
          "category": { "not": {} },
          "cloneofid": { "not": {} },
          "roms": { "not": {} },
          "disks": { "not": {} }
        }
      }
    },
    {
      "if": { "properties": { "op": { "const": "upsert" } } },
      "then": {
        "required": ["source", "system", "datVersion", "id", "name"],
        "anyOf": [
          { "required": ["roms"] },
          { "required": ["disks"] }
        ],
        "properties": {
          "key": { "not": {} }
        }
      }
    }
  ]
}
